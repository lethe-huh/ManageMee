generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model InventoryItem {
  id              String             @id @default(uuid())
  name            String
  category        String
  quantity        Float
  unit            String
  minQuantity     Float
  supplier        String
  lastUpdated     DateTime           @updatedAt
  targetPrice     Float
  pendingRestock  Json?
  image           String?
  menuIngredients RecipeIngredient[]
  supplierPrices  SupplierPrice[]
}

model Supplier {
  id     String          @id @default(uuid())
  name   String
  phone  String
  items  String[]
  prices SupplierPrice[]
}

model SupplierPrice {
  id              String        @id @default(uuid())
  supplierId      String
  supplierName    String
  inventoryItemId String
  price           Float
  lastUpdated     DateTime      @updatedAt

  supplier        Supplier      @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([inventoryItemId])
}

model MenuItem {
  id          String             @id @default(uuid())
  name        String
  price       Float
  category    String
  image       String?

  ingredients RecipeIngredient[]
  sales       SaleRecord[]
}

model RecipeIngredient {
  id                String        @id @default(uuid())
  menuItemId        String
  inventoryItemId   String
  inventoryItemName String
  quantity          Float
  unit              String

  menuItem          MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  inventoryItem     InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([menuItemId])
  @@index([inventoryItemId])
}

model SaleRecord {
  id             String   @id @default(uuid())
  menuItemId     String?
  menuItemName   String
  menuItemPrice  Float    @default(0)
  quantity       Int
  timestamp      DateTime @default(now())

  menuItem     MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([menuItemId])
  @@index([timestamp])
}

model StallSettings {
  id             String   @id @default(uuid())
  stallName      String   @default("King Chicken Stall")
  ownerName      String   @default("Owner")
  location       String   @default("Block 123, Chinatown Food Centre")
  lowStockAlerts Boolean  @default(true)
  currency       String   @default("SGD")
  language       String   @default("English")
  updatedAt      DateTime @updatedAt
}