generator client {
  provider = "prisma-client-js" 
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stalls       Stall[]
}

model Stall {
  id                   String   @id @default(uuid())
  ownerId              String
  stallName            String
  location             String
  stallCategories      String[]
  ingredientCategories String[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  owner          User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  settings       StallSettings?
  inventoryItems InventoryItem[]
  suppliers      Supplier[]
  menuItems      MenuItem[]
  sales          SaleRecord[]

  @@index([ownerId])
}

model InventoryItem {
  id              String             @id @default(uuid())
  stallId         String
  name            String
  category        String
  quantity        Float
  unit            String
  minQuantity     Float
  supplier        String
  lastUpdated     DateTime           @updatedAt
  targetPrice     Float
  pendingRestock  Json?
  image           String?

  stall           Stall              @relation(fields: [stallId], references: [id], onDelete: Cascade)
  menuIngredients RecipeIngredient[]
  supplierPrices  SupplierPrice[]

  @@index([stallId])
}

model Supplier {
  id      String          @id @default(uuid())
  stallId String
  name    String
  phone   String
  items   String[]

  stall   Stall           @relation(fields: [stallId], references: [id], onDelete: Cascade)
  prices  SupplierPrice[]

  @@index([stallId])
}

model SupplierPrice {
  id              String        @id @default(uuid())
  supplierId      String
  supplierName    String
  inventoryItemId String
  price           Float
  lastUpdated     DateTime      @updatedAt

  supplier        Supplier      @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([inventoryItemId])
}

model MenuItem {
  id          String             @id @default(uuid())
  stallId     String
  name        String
  price       Float
  category    String
  image       String?

  stall       Stall              @relation(fields: [stallId], references: [id], onDelete: Cascade)
  ingredients RecipeIngredient[]
  sales       SaleRecord[]

  @@index([stallId])
}

model RecipeIngredient {
  id                String        @id @default(uuid())
  menuItemId        String
  inventoryItemId   String
  inventoryItemName String
  quantity          Float
  unit              String

  menuItem          MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  inventoryItem     InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([menuItemId])
  @@index([inventoryItemId])
}

model SaleRecord {
  id            String    @id @default(uuid())
  stallId       String
  menuItemId    String?
  menuItemName  String
  menuItemPrice Float
  quantity      Int
  timestamp     DateTime  @default(now())

  stall         Stall     @relation(fields: [stallId], references: [id], onDelete: Cascade)
  menuItem      MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([stallId])
  @@index([menuItemId])
  @@index([timestamp])
}

model StallSettings {
  id             String   @id @default(uuid())
  stallId        String   @unique
  lowStockAlerts Boolean  @default(true)
  currency       String   @default("SGD")
  language       String   @default("English")
  updatedAt      DateTime @updatedAt

  stall          Stall    @relation(fields: [stallId], references: [id], onDelete: Cascade)
}